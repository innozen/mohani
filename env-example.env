# Gemini API 키 설정
# Google AI Studio (https://makersuite.google.com/app/apikey)에서 발급받은 API 키를 입력하세요
GEMINI_API_KEY=AIzaSyDnMappyL5xIZusPbKkMWqFR8QXGhDPQ-w

# 사용 방법:
# 1. 이 파일을 .env로 복사하세요: cp env-example.txt .env
# 2. your_gemini_api_key_here를 실제 API 키로 교체하세요
# 3. Netlify에 배포할 때는 Netlify 대시보드의 Environment Variables에서 설정하세요

# 로컬 개발 시:
# - .env 파일을 생성하고 위의 환경변수를 설정하세요
# - Netlify CLI를 사용하여 로컬에서 테스트할 수 있습니다

# Netlify 배포 시:
# - Netlify 대시보드 > Site settings > Environment variables
# - GEMINI_API_KEY 변수를 추가하고 실제 API 키 값을 입력하세요
